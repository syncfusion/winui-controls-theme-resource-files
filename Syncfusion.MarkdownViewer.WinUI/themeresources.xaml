<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Syncfusion.Core.WinUI/Themes/Common.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <x:String x:Key="Light">
        body
        {
            padding: 8px;
            background-color: #F3F3F3;
            font-family: 'Segoe UI';
            font-style: normal;
            font-size: var(--user-font-size, 14px);
            line-height: 1.4;
            font-weight: 400;
            margin:-0px;
            color: #000000E4;
        }

        h1
        {
            margin-top: 10px;
            margin-bottom: 4px;
            font-weight: 700;
            font-size: 28px;
            line-height: 36px;
            font-family: 'Segoe UI';
            color: #000000E4;
        }

        h2
        {
            margin-top: 10px;
            margin-bottom: 4px;
            margin-top: 0px;
            margin-bottom: 4px;
            font-weight: 700;
            font-size: 24px;
            line-height: 32px;
            font-family: 'Segoe UI';
            color: #000000E4;
        }

        h3
        {
            margin-top: 10px;
            margin-bottom: 4px;
            font-weight: 600;
            font-size: 22px;
            line-height: 28px;
            font-family: 'Segoe UI';
            color: #000000E4;
        }

        h4
        {
            margin-top: 10px;
            margin-bottom: 4px;
            font-weight: 600;
            font-family: 'Segoe UI';
            color: #000000E4;
            line-height: 26px;
            font-size: 20px;
        }

        h5
        {
            margin-top: 10px;
            margin-bottom: 4px;
            font-weight: 600;
            font-size: 18px;
            line-height: 26px;
            font-family: 'Segoe UI';
            color: #000000E4;
        }

        h6
        {
            margin-top: 10px;
            margin-bottom: 4px;
            font-family: 'Segoe UI';
            font-weight: 600;
            font-size: 16px;
            color: #000000E4;
            line-height: 24px;
        }

        blockquote
        {
            border-left: 4px solid;
            margin-left: 0;
            padding-left: 8px;
            border-left-color: #0000000F;
            color: #000000E4;
        }

        table
        {
            width: 100%;
            border-collapse: collapse;
            overflow: hidden;
            margin-bottom: 20px;
            margin-top: 10px;
            background-color : #F3F3F3;
            border: 1px solid var(--table-border-color,#00000014);
        }

        td
        {
            border: 1px solid var(--table-border-color,#00000014);
            padding: 8px;
            text-align: left;
            font-size: 14px;
            color: #000000E4;
            font-weight: 400;
        }

        th
        {
            border: 1px solid var(--table-border-color,#00000014);
            padding: 8px;
            text-align: left;
            font-size: 12px;
            color: #0000009B;
            font-weight: 400;
        }

        a
        {
            color: #005FB8;
            text-decoration: none;
        }

        a:hover, a:active
        {
            color: #005FB8E5;
            text-decoration: underline;
        }

        ul li, ol li
        {
            margin-bottom: 4px;
            font-family: 'Segoe UI';
            font-size: var(--user-font-size, 14px);
            line-height: 1.4;
            color: #000000E4;
            font-weight: 400;
        }
        
        /* Inline code only (not inside pre) */
        :not(pre) > code 
        {
           font-family: 'Segoe UI';
           background-color: #005FB8;
           padding: 8px;
           display: block;
           border-radius: 4px;
           font-style: Regular;
           color: #FFFFFF;
           font-size: 14px;
           line-height: normal;
        }

        pre 
        {
           font-family: 'Segoe UI';
           background-color: #00000006; 
           padding: 8px;
           border-radius: 4px;
           margin: 15px 0;
           font-size: var(--user-font-size, 14px);
           line-height: 1.4;
           color: #000000E4;
           font-style: Regular;
        }

        ::-webkit-scrollbar
        {
            width: 12px;
            height: 12px;
        }

        ::-webkit-scrollbar-track
        {
            background-color: #F5F5F5;
            border-radius: 6px;
        }

        ::-webkit-scrollbar-thumb
        {
            background-color: #C1C1C1;
            border-radius: 6px;
            border: 2px solid #F5F5F5;
        }

        ::-webkit-scrollbar-thumb:hover
        {
            background-color: #A8A8A8;
        }

        ::-webkit-scrollbar-thumb:active
        {
            background-color: #787878;
        }

        ::-webkit-scrollbar-corner
        {
            background-color: #F5F5F5;
        }

        .mermaid
        {
            text-align: center;
            margin: 10px 0;
            max-width: 100%;
            overflow-x: auto;
        }

        .mermaid svg
        {
            max-width: 100%;
            height: auto;
        }

        hr
        {
            border: none;
            border-top-width:1px;
            border-top-style:solid;
            border-top-color: #0000000F;
            margin: 8px 0;
        }

        sup
        {
            font-size: smaller;
            vertical-align: super;
            color: #000000E4;
        }

        sub
        {
            font-size: smaller;
            vertical-align: sub;
            color: #000000E4;
        }
        
        input[type="checkbox"] 
        {
            position: relative;
            top: 1px;         
        }
    </x:String>

